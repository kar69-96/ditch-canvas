{
  "name": "canvas-wrapper",
  "version": "1.0.0",
  "description": "Canvas helper with cookie authentication and assignment overrides",
  "main": "server.js",
  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "nodemon server.js",
    "dev:all": "concurrently \"npm run dev:server\" \"cd frontend && npm run dev\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "start": "node server.js",
    "test": "mocha 'tests/**/*.test.js' --recursive --timeout 10000",
    "test:watch": "mocha 'tests/**/*.test.js' --recursive --watch",
    "test:unit": "mocha 'tests/unit/**/*.test.js' --recursive",
    "test:integration": "mocha 'tests/integration/**/*.test.js' --recursive --timeout 10000",
    "auth:extract-cookies": "node src/core/extract-cookies.js",
    "auth:extract-cookies:streaming:local": "node src/core/extract-cookies-streaming.js",
    "auth:extract-cookies:local": "LOCAL_AUTH=true node src/core/extract-cookies.js",
    "crawl:canvas": "node src/crawler/canvas-crawler.js",
    "crawl:map": "MAP_ONLY=true node src/crawler/canvas-crawler.js",
    "crawl:extract": "node src/crawler/canvas-crawler.js",
        "aws:extract": "node scripts/aws/run-aws-extraction.js",
        "aws:check": "node scripts/aws/check-aws-setup.js",
        "aws:deploy-streaming": "node scripts/aws/deploy-streaming.js",
        "aws:setup-streaming": "bash scripts/aws/setup-streaming-aws-cli.sh",
    "compare:metrics": "node scripts/utils/compare-metrics.js",
    "update": "node scripts/utils/update.js",
        "aws:update": "node scripts/aws/run-aws-update.js",
    "seed:chat": "node scripts/utils/seed-chat-data.js"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.939.0",
    "@aws-sdk/client-ec2": "^3.939.0",
    "@browserbasehq/sdk": "^2.6.0",
    "@notionhq/client": "^2.3.0",
    "@supabase/supabase-js": "^2.86.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "crawlee": "^3.15.3",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "googleapis": "^128.0.0",
    "http-proxy": "^1.18.1",
    "node-fetch": "^3.3.2",
    "p-limit": "^7.2.0",
    "playwright-core": "^1.41.1",
    "socket.io": "^4.5.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "canvas",
    "lms",
    "education"
  ],
  "author": "Your Name",
  "license": "MIT"
}
