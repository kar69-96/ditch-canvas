{
  "name": "canvas-wrapper",
  "version": "1.0.0",
  "description": "Canvas LMS data management platform with daily updates and integrations",
  "main": "server.js",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "dev:backend": "NODE_ENV=development node -r dotenv/config server.js dotenv_config_path=.env.development",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:streaming": "NODE_ENV=development node -r dotenv/config src/core/extract-cookies-streaming.js dotenv_config_path=.env.development",
    "dev:server": "NODE_ENV=development nodemon -r dotenv/config server.js dotenv_config_path=.env.development",
    "dev:all": "concurrently \"npm run dev:server\" \"cd frontend && npm run dev\" --names \"backend,frontend\" --prefix-colors \"blue,green\"",
    "start": "node server.js",
    "prod:build": "cd frontend && npm run build",
    "prod:deploy": "npm run prod:build && vercel --prod --yes",
    "prod:preview": "vercel",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "mocha --config tests/.mocharc.json",
    "test:backend:unit": "mocha tests/backend/unit/**/*.test.js --timeout 10000",
    "test:backend:integration": "mocha tests/backend/integration/**/*.test.js --timeout 10000",
    "test:backend:e2e": "mocha tests/backend/e2e/**/*.test.js --timeout 30000",
    "test:backend:watch": "mocha tests/backend/**/*.test.js --watch --timeout 10000",
    "test:backend:coverage": "c8 --config .c8rc.json npm run test:backend",
    "test:frontend": "cd frontend && npm run test",
    "test:frontend:unit": "cd frontend && npm run test:unit",
    "test:frontend:integration": "cd frontend && npm run test:integration",
    "test:frontend:e2e": "cd frontend && npm run test:e2e",
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:coverage": "npm run test:backend:coverage && cd frontend && npm run test:coverage",
    "test:watch": "mocha tests/backend/**/*.test.js --watch --timeout 10000",
    "test:unit": "mocha tests/backend/unit/**/*.test.js --recursive",
    "test:integration": "mocha tests/backend/integration/**/*.test.js --recursive --timeout 10000",
    "compare:metrics": "node scripts/utils/compare-metrics.js",
    "update": "node scripts/utils/update.js",
    "update:dry-run": "UPDATE_DRY_RUN=true AUTO_UPLOAD_TO_SUPABASE=false node scripts/utils/update.js",
    "seed:chat": "node scripts/utils/seed-chat-data.js",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\" --ignore-path .gitignore"
  },
  "dependencies": {
    "@emailjs/nodejs": "^5.0.2",
    "@notionhq/client": "^2.3.0",
    "@supabase/supabase-js": "^2.86.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "crawlee": "^3.15.3",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "googleapis": "^128.0.0",
    "http-proxy": "^1.18.1",
    "node-fetch": "^3.3.2",
    "playwright-core": "^1.57.0",
    "socket.io": "^4.5.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "chai": "^6.2.2",
    "concurrently": "^9.2.1",
    "memfs": "^4.51.1",
    "mocha": "^10.2.0",
    "mock-fs": "^5.5.0",
    "nock": "^14.0.10",
    "nodemon": "^3.0.1",
    "pg": "^8.16.3",
    "prettier": "^3.7.4",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "canvas",
    "lms",
    "education"
  ],
  "author": "Your Name",
  "license": "MIT"
}
