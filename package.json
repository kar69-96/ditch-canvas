{
  "name": "yay-final",
  "version": "1.0.0",
  "description": "Canvas LMS data extraction and management system",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev:server --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "start": "npm start --workspace=backend",
    "build": "npm run build:frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "install:all": "npm install",
    "backend:auth:extract-cookies": "cd backend && npm run auth:extract-cookies",
    "backend:auth:extract-cookies:browserbase": "cd backend && npm run auth:extract-cookies:browserbase",
    "backend:auth:extract-cookies:local": "cd backend && npm run auth:extract-cookies:local",
    "backend:auth:extract-cookies:streaming": "cd backend && npm run auth:extract-cookies:streaming",
    "backend:auth:extract-cookies:streaming:fast": "cd backend && npm run auth:extract-cookies:streaming:fast",
    "backend:auth:extract-cookies:streaming:setup": "cd backend && npm run auth:extract-cookies:streaming:setup",
    "backend:auth:extract-cookies:streaming:local": "cd backend && npm run auth:extract-cookies:streaming:local",
    "backend:auth:server": "cd backend && npm run auth:server",
    "backend:crawl:canvas": "cd backend && npm run crawl:canvas",
    "backend:crawl:map": "cd backend && npm run crawl:map",
    "backend:crawl:extract": "cd backend && npm run crawl:extract",
    "backend:aws:extract": "cd backend && npm run aws:extract",
    "backend:aws:check": "cd backend && npm run aws:check",
    "backend:aws:update": "cd backend && npm run aws:update",
    "backend:compare:metrics": "cd backend && npm run compare:metrics",
    "backend:update": "cd backend && npm run update",
    "frontend:supabase:show": "cd frontend && npm run supabase:show",
    "frontend:supabase:sync": "cd frontend && npm run supabase:sync",
    "frontend:supabase:migrate": "cd frontend && npm run supabase:migrate",
    "frontend:supabase:upload-data": "cd frontend && npm run supabase:upload-data",
    "frontend:supabase:push": "cd frontend && npm run supabase:push",
    "frontend:supabase:status": "cd frontend && npm run supabase:status",
    "frontend:supabase:link": "cd frontend && npm run supabase:link",
    "frontend:supabase:setup": "cd frontend && npm run supabase:setup",
    "frontend:lint": "cd frontend && npm run lint",
    "frontend:preview": "cd frontend && npm run preview"
  },
  "keywords": [
    "canvas",
    "lms",
    "education",
    "data-extraction"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "pg": "^8.16.3"
  },
  "dependencies": {
    "@browserbasehq/sdk": "^2.6.0",
    "playwright-core": "^1.41.1"
  }
}
