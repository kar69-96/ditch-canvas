# ============================================
# Canvas Wrapper Backend - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ============================================
# Server Configuration
# ============================================
# Port for the backend server
PORT=3000

# Host to bind the server to
# Use 0.0.0.0 for production to accept connections from all interfaces
# Use 127.0.0.1 for development (localhost only)
HOST=127.0.0.1

# Node environment (development, production, test)
NODE_ENV=development

# ============================================
# CORS Configuration (REQUIRED FOR PRODUCTION)
# ============================================
# Comma-separated list of allowed frontend origins
# In production, this MUST be set to your actual frontend URL(s)
# Examples:
#   - Single origin: CLIENT_ORIGIN=https://app.example.com
#   - Multiple origins: CLIENT_ORIGIN=https://app.example.com,https://www.example.com
#   - With ports: CLIENT_ORIGIN=https://app.example.com,http://localhost:5173
#
# Development: Leave unset to use default localhost origins
# Production: REQUIRED - Set to your production frontend URL(s)
CLIENT_ORIGIN=

# ============================================
# Canvas Configuration
# ============================================
# Canvas LMS instance URL
CANVAS_URL=https://canvas.colorado.edu

# ============================================
# Cookie Encryption
# ============================================
# Secret key for encrypting cookies (generate a secure random string)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_ENCRYPTION_KEY=

# ============================================
# Streaming Authentication Server
# ============================================
# Port for the internal streaming authentication server
STREAMING_PORT=3002

# ============================================
# Browserless Configuration (Optional)
# ============================================
# If using Browserless Cloud, set your API token
# BROWSERLESS_API_TOKEN=

# If using self-hosted Browserless, configure these:
# BROWSERLESS_WS=ws://localhost:3000
# BROWSERLESS_HTTP=http://localhost:3000
# BROWSERLESS_TOKEN=

# ============================================
# Supabase Configuration (Optional)
# ============================================
# Supabase project URL
# SUPABASE_URL=

# Supabase service role key (for server-side operations)
# SUPABASE_SERVICE_KEY=

# ============================================
# Data Storage
# ============================================
# Directory for storing authentication data (cookies, sessions)
# Defaults to: ~/canvas-wrapper-data/auth (or backend/data/auth if HOME not set)
# OUTPUT_DIR=

# ============================================
# Production Checklist
# ============================================
# Before deploying to production, ensure:
# 1. NODE_ENV=production
# 2. CLIENT_ORIGIN is set to your production frontend URL(s)
# 3. COOKIE_ENCRYPTION_KEY is set to a secure random value
# 4. HOST is set appropriately (0.0.0.0 for Docker/cloud, or specific IP)
# 5. PORT is set to your desired port (or use your platform's port binding)
# 6. All sensitive credentials are properly secured and not committed to git
