{
    "name": "canvas-wrapper",
    "version": "1.0.0",
    "description": "Canvas helper with cookie authentication and assignment overrides",
    "main": "server.js",
    "scripts": {
        "dev": "npm run dev:server",
        "dev:server": "nodemon server.js",
        "start": "node server.js",
        "auth:extract-cookies": "node src/core/extract-cookies.js",
        "auth:extract-cookies:browserbase": "node src/core/extract-cookies-browserbase.js",
        "auth:extract-cookies:streaming": "node src/core/extract-cookies-streaming-ec2.js",
        "auth:extract-cookies:streaming:local": "node src/core/extract-cookies-streaming.js",
        "auth:extract-cookies:local": "LOCAL_AUTH=true node src/core/extract-cookies.js",
        "auth:server": "node src/core/auth-server.js",
        "crawl:canvas": "node src/crawler/canvas-crawler.js",
        "crawl:map": "MAP_ONLY=true node src/crawler/canvas-crawler.js",
        "crawl:extract": "node src/crawler/canvas-crawler.js",
        "aws:extract": "node aws/run-aws-extraction.js",
        "aws:check": "node aws/check-aws-setup.js",
        "aws:deploy-streaming": "node aws/deploy-streaming.js",
        "aws:setup-streaming": "bash aws/setup-streaming-aws-cli.sh",
        "compare:metrics": "node scripts/compare-metrics.js",
        "update": "node scripts/update.js",
        "aws:update": "node aws/run-aws-update.js"
    },
    "dependencies": {
        "@aws-sdk/client-cloudwatch": "^3.939.0",
        "@aws-sdk/client-ec2": "^3.939.0",
        "@supabase/supabase-js": "^2.86.0",
        "cors": "^2.8.5",
        "crawlee": "^3.15.3",
        "dotenv": "^16.6.1",
        "express": "^4.18.2",
    "@browserbasehq/sdk": "^2.6.0",
    "node-fetch": "^3.3.2",
        "p-limit": "^7.2.0",
        "playwright-core": "^1.41.1",
        "socket.io": "^4.5.4",
        "ws": "^8.14.2"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "nodemon": "^3.0.1"
    },
    "keywords": [
        "canvas",
        "lms",
        "education"
    ],
    "author": "Your Name",
    "license": "MIT"
}
