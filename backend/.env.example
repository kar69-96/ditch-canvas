# Server configuration
PORT=3000
HOST=127.0.0.1

# Frontend origin whitelist (comma separated list)
CLIENT_ORIGIN=http://localhost:5173

# Cookie encryption key (32 byte hex string)
COOKIE_ENCRYPTION_KEY=replace_with_64_hex_chars

# Browserbase API access
BROWSERBASE_API_KEY=replace_with_browserbase_api_key
BROWSERBASE_PROJECT_ID=replace_with_project_id

# Canvas login defaults
CANVAS_LOGIN_URL=https://canvas.colorado.edu/login
BROWSERBASE_SETUP_TIMEOUT=900
BROWSERBASE_VALIDATE_TIMEOUT=180

# Deep content discovery controls
CANVAS_DEEP_DEPTH=2
CANVAS_DEEP_LIMIT=200
