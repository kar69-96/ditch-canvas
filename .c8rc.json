{
  "all": true,
  "include": ["src/**/*.js"],
  "exclude": [
    "**/*.test.js",
    "**/*.spec.js",
    "**/node_modules/**",
    "tests/**",
    "frontend/**"
  ],
  "reporter": ["text", "html", "lcov"],
  "check-coverage": true,
  "branches": 70,
  "functions": 70,
  "lines": 70,
  "statements": 70,
  "report-dir": "./coverage"
}
